#include <stdio.h>

int StrLen(const char *str)
{
  int i = 0;
  for(; str[i] != '\0'; i++);
  
  return i;
}

int main()

{
  char *str = "hello";
  int k = StrLen(str);
  printf("length: %d\n", k);
  
  return 0;
