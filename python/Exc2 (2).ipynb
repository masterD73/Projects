services:
  fetcher:
    build:
      context: .
      dockerfile: fetch.Dockerfile
    volumes:
      - ./logging/fetcher:/fetcher/logs
      - ./files:/fetcher/files
    deploy:
      replicas: 20
    networks:
      - crawler_rabbit

  extractor:
    build:
      context: .
      dockerfile: extractor.Dockerfile
    volumes:
      - ./logging/extractor:/extractor/logs
    deploy:
      replicas: 1
    networks:
      - crawler_rabbit

  manager:
    build:
      context: .
      dockerfile: manager.Dockerfile
    volumes:
      - ./logging/manager:/manager/logs
    deploy:
      replicas: 1
    networks:
      - crawler_rabbit

networks:
  crawler_rabbit:
    external: true
